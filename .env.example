# Zenith API — copy to .env and adjust. Every default is free to run.

# API
PORT=3000
HOST=0.0.0.0

# PostgreSQL (system of record) — matches infra/docker-compose.yml
DATABASE_URL=postgres://zenith:zenith@localhost:5432/zenith

# Ollama (local open-source LLM runtime for AI Buddy)
OLLAMA_URL=http://localhost:11434

# Embedding model for implicit clinical screening (CSI engine).
# bge-m3 (MIT, ~1.2GB) understands 100+ languages — required for detection
# in Hindi/Tamil/Bengali etc. nomic-embed-text is smaller but English-only.
#   ollama pull bge-m3
EMBED_MODEL=bge-m3

# AI Buddy provider. Default "ollama" = fully local, conversation text never
# leaves your server. For faster replies on weak hardware, any free
# OpenAI-compatible API works (provider then sees conversation text — never
# identity; crisis detection always stays local):
#   LLM_PROVIDER=openai-compat
#   LLM_API_BASE_URL=https://api.groq.com/openai/v1
#   LLM_API_KEY=gsk_...
#   LLM_API_MODEL=llama-3.3-70b-versatile
LLM_PROVIDER=ollama

# Anonymous session token signing secret — set a long random value in production
SESSION_TOKEN_SECRET=dev-only-secret-change-me
# Set true when serving over HTTPS
COOKIE_SECURE=false

# Worker
PURGE_INTERVAL_SECONDS=60
SESSION_INACTIVITY_MINUTES=10

# Whisper STT sidecar (services/inference) — voice input in every browser
STT_URL=http://127.0.0.1:8090
